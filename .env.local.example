# Supabase - Get from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Pipeline auth - make up any random string
PIPELINE_SECRET=your-random-secret-here

# GitHub - Get from: github.com/settings/tokens (scope: public_repo)
GITHUB_TOKEN=ghp_your-token-here

# X/Twitter - Get from: developer.twitter.com (Basic tier is free)
X_BEARER_TOKEN=your-bearer-token-here

